fn main() {
    // Creating variables with let
    let n = 17
    let pi = 3.141592653589793
    let message = "And now for something completely different"

    // Using variables in expressions
    print(n + 25)
    print(2 * pi)

    // Using variables in function calls
    print(round(pi))
    print(len(message))

    // Mutable variable with let mut
    let mut x = 5
    print(x)
    x = 10
    print(x)
}
