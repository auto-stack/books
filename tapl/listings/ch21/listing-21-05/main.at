// Auto
fn main() {
    var now = Time.now()
    println(now)

    var formatted = now.format("%Y-%m-%d %H:%M:%S")
    println(formatted)

    var parsed = Time.parse("2025-01-15 10:30:00", "%Y-%m-%d %H:%M:%S")
    println(parsed)

    var duration = Duration.hours(2) + Duration.minutes(30)
    println(duration)

    var later = now + duration
    println(later)

    var diff = later - now
    println(diff.total_minutes())
}
