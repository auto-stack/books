fn largest<T>(list []T) T {
    var largest = list[0]
    for item in list {
        if item > largest {
            largest = item
        }
    }
    largest
}

fn main() {
    var numbers = [34, 50, 25, 100, 65]
    print(largest(numbers))
    var chars = ['y', 'm', 'a', 'q']
    print(largest(chars))
}
