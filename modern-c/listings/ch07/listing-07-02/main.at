fn factorial(n int) int {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

fn fibonacci(n int) int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    fibonacci(n - 1) + fibonacci(n - 2)
}

fn main() {
    print("5! =", factorial(5))
    print("10! =", factorial(10))
    for i in 0..10 {
        print("fib(" + str(i) + ") =", fibonacci(i))
    }
}
