type Point {
    x float
    y float
}

fn Point.distance_from_origin(p Point) float {
    (p.x * p.x + p.y * p.y) ** 0.5
}

fn Point.translate(p Point, dx float, dy float) Point {
    Point(p.x + dx, p.y + dy)
}

fn main() {
    let p Point = Point(3.0, 4.0)
    print("Point:", p.x, p.y)
    print("Distance from origin:", p.distance_from_origin(p))
    let moved Point = p.translate(p, 1.0, 2.0)
    print("Moved to:", moved.x, moved.y)
}
