//! # My Package
//!
//! `my_package` is a collection of utilities to make performing certain
//! calculations more convenient.

/// Adds one to the number given.
// --snip--
///
/// # Examples
///
/// ```
/// let arg = 5
/// let answer = my_package::add_one(arg)
///
/// assert_eq(6, answer)
/// ```
pub fn add_one(x int) int {
    x + 1
}
