// Listing 9-1: Using ?T (Option) and ?? for safe value access
fn find_item(index int) ?int {
    if index < 0 {
        return None
    }
    Some(index * 10)
}

fn main() {
    let result1 = find_item(5)
    let result2 = find_item(-1)

    let value = result1 ?? 0
    print(f"Value: ${value}")

    let default = result2 ?? 99
    print(f"Default: ${default}")
}
