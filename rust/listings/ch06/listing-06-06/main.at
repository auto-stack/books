// Listing 6-6: Pattern matching that binds values
enum Atom {
    Int int
    Char char
    Float float
}

fn main() {
    let atom = Atom.Int(11)

    is atom {
        Atom.Int(i) => print(f"Got Int: ${i}")
        Atom.Char(c) => print(f"Got Char: ${c}")
        Atom.Float(f) => print(f"Got Float: ${f}")
    }
}
