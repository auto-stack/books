fn main(args [str]) {
    if len(args) < 2 {
        print("Usage: todo <command> [args]")
        print("Commands: add, list, done")
        return
    }

    let cmd str = args[1]
    is cmd {
        "add" => print("Adding task...")
        "list" => print("Listing tasks...")
        "done" => print("Completing task...")
        else => print("Unknown command:", cmd)
    }
}
