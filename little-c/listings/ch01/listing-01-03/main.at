fn classify(n int) str {
    if n > 0 {
        "positive"
    } else if n < 0 {
        "negative"
    } else {
        "zero"
    }
}

fn describe(x int) str {
    is x {
        0 => "nothing"
        1 => "one"
        2 => "two"
        else => "many"
    }
}

fn main() {
    print(classify(5))
    print(classify(-3))
    print(classify(0))
    print(describe(0))
    print(describe(1))
    print(describe(5))
}
