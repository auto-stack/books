fn main() {
    let mut ab: HashMap<str, int> = {"swaroop": 4098, "matz": 4139}
    print(f"ab is $ab")

    ab["guido"] = 4127
    print(f"\nab is now $ab")

    // delete a key-value pair
    // ab.remove("swaroop")
    print(f"\nab is now $ab")

    for name in ab.keys() {
        print(f"Contact $name at $ab[name]")
    }

    if ab.contains_key("guido") {
        let addr = ab["guido"]
        print(f"\nguido's address is $addr")
    }
}
